  },
  "peerDependencies": {
    "nostr-tools": ">=2.17.0 <3"
  },
  "devDependencies": {
    "@types/node": "^22.19.8",
    "nostr-tools": "2.23.5",
    "typescript": "^5.3.0"
  }
