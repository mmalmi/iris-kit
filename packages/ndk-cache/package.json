{
  "name": "ndk-cache",
  "version": "0.2.0",
  "license": "MIT",
  "private": true,
  "description": "Dexie IndexedDB cache adapter for NDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run"
  },
  "dependencies": {
    "debug": "4.4.3",
    "dexie": "4.4.2",
    "ndk": "https://github.com/mmalmi/iris-kit/releases/download/runtime-v0.2.0/ndk-0.2.0.tgz",
    "nostr-tools": "2.23.3",
    "typescript-lru-cache": "2.0.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^22.19.8",
    "fake-indexeddb": "^6.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  }
}
